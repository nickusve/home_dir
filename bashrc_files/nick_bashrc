# .bashrc

# Check if this has already been sourced to prevent duplicating operations
if [ ! -z "$nick_bashrc_loaded" ]; then
    return 0
fi

# To used to mark this being loaded, checked above
export nick_bashrc_loaded="true"

# Add $HOME/.local/bin to PATH if not already present.
if ! [[ "$PATH" =~ "$HOME/.local/bin:" ]]; then
  PATH="$HOME/.local/bin:$PATH"
fi

# Add ~/.local/lib to LD_LIBRARY_PATH so local libraries can be used
if ! [[ "$LD_LIBRARY_PATH" =~ "$HOME/.local/lib:" ]]; then
  export LD_LIBRARY_PATH=$HOME/.local/lib:$LD_LIBRARY_PATH
fi

# Source .nick_alias if it exists
if [ -f $HOME/.nick_alias ]; then
  . $HOME/.nick_alias
fi

# For SSH agent startup via user service
export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"

# For X11 forwarding over SSH
export XAUTHORITY=$HOME/.Xauthority
